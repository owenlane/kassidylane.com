# Lead routing — set these in Vercel Project Settings → Environment Variables.
# All are optional for the build; the lead API degrades gracefully if absent.

# Resend (transactional email of new leads)
RESEND_API_KEY=
LEAD_NOTIFY_TO=kassidylane@gmail.com
LEAD_NOTIFY_FROM=leads@kassidylane.com

# Supabase (optional lead storage). Expects a table named "leads".
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical/sitemap/OG)
NEXT_PUBLIC_SITE_URL=https://kassidylane.com
